# ─────────────────────────────────────────────────────────────────────────────
# .env  — Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Your BotFather token
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Comma-separated Telegram user IDs with admin rights
# e.g. ADMIN_IDS=123456789,987654321
ADMIN_IDS=YOUR_USER_ID_HERE

# Price spike threshold in percent (default: 50)
# Spike alerts go back to whichever group the call was made in. No central channel needed.
SPIKE_THRESHOLD=50

# How often to check prices in seconds (default: 300 = 5 minutes)
MONITOR_INTERVAL=300
